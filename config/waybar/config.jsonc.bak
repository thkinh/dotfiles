{
  "position": "top",
  "margin-top": 3,
  "modules-left": ["battery","cpu","temperature","memory", "network","tray"], 
  "modules-center": ["hyprland/workspaces", "custom/media"],
  "modules-right": ["clock", "custom/weather", "pulseaudio", "backlight"],
  "tray": {
    "format": "{}",  // Font Awesome Bluetooth icon
    "icon-size": 20,
    "spacing": 10
  },
  "custom/keyboard": {
    "format": "{}",
    "exec": "~/.config/waybar/scripts/toggle_keyboard.sh check",
    "on-click": "~/.config/waybar/scripts/toggle_keyboard.sh",
    "return-type": "json",
    "format-icons": ["ÔÄĆ", "ÔÄć"],
    "tooltip": true,
    "signal": 10
  },
  "custom/ibus": {
    "format": "{}",
    "exec": "~/.config/waybar/scripts/ibus_toggle.sh",
    "on-click": "~/.config/waybar/scripts/ibus_toggle.sh toggle",
    "return-type": "json",
    "tooltip": true,
    "signal": 9
  },
  "custom/pacman": {
    "format": " {}  ÔÜá ",
    "interval": "once",
    "exec": "checkupdates | wc -l",
    "on-click": "update-system",
    "signal": 8
  },
  "temperature": {
    "critical-threshold": 80,
    "format": "{icon} {temperatureC}¬įC",
    "format-icons": ["ůĪÉÉ", "ůįĒŹ", "ůĪÉā"]
  },
  "cpu": {
    "format": "<span font='20px'>Ôíľ</span> {usage}%"
  },
  "memory": {
    "format": "ÓŅÖ   {}%"
  },
  "backlight": {
    "format": "ÔÉę„ÄÄ{percent}%",
    "format-icons": ["ÔÜÖ", "ÔĄĎ"],
  },
  "custom/media": {
    "format": "{}",
    "escape": true,
    "return-type": "json",
    "max-length": 8,
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl stop",
    "smooth-scrolling-threshold": 10, // This value was tested using a trackpad, it should be lowered if using a mouse.
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous",
    "tool-tip": true,
    "exec": "$HOME/.config/waybar/scripts/mediaplayer.py 2> /dev/null" // Script in resources/custom_modules folder
  },

  "battery": {
    "format": "{icon}  {capacity}%",
    "format-charging": "ůįāĄ  {capacity}%",
    "format-icons": ["ůįĀļ", "ůįĀĽ", "ůįĀľ", "ůįĀĹ", "ůįĀĺ", "ůįĀŅ", "ůįāÄ", "ůįāĀ", "ůįāā", "ůįĀĻ"]
  },

  "clock": {
    "format-alt": "ůį•Ē   {:%I:%M %p}",
    "format": "<span font='18px'>ůį•Ē</span> {:%a, %d. %b  %I:%M %p}",
    "tooltip": true
  },

  "pulseaudio": {
    "format": " <span font='20px'>{icon}</span>{volume}%",
    "format-bluetooth": "<span font='20px'>ůįāĪ</span>  {volume}%",
    "format-muted": "ůįĖĀ",
    "scroll-step": 1,
    "on-click": "pavucontrol",
    "ignored-sinks": ["Easy Effects Sink"],
    "format-icons": {
      "headphone": "ÔÄ•  ",
      "hands-free": "ÔĖź ",
      "headset": "ůįčé ",
      "phone": "Ôāē ",
      "portable": "Ôāē ",
      "car": "ÔÜĻ",
      "default": ["ůįĖÄ", "ůįēĺ"]
    }
  },

  "network": {
    "interface": "wlan0",
    "format": "{ifname}",
    "format-wifi": "<span font='24px'>{icon}</span>   {essid}",
    "format-ethernet": "ůįąÄ   {ipaddr}/{cidr}",
    "format-disconnected": "ůį§≠   disconnected",
    "max-length": 50,
    "format-icons": ["ůį§Į", "ůį§ü", "ůį§Ę", "ůį§•", "ůį§®"]
  },

  "hyprland/workspaces": {
    "format": "{icon}",
    "on-click": "activate",
    "format-icons": {
      "urgent": "ůįÄ®",
      "default": "ÔÜí",
      "active": "ÔĄĎ"
    },

    "sort-by-number": true
  },

  "backlight": {
    "device": "intel_backlight",
    "format": "<span font='20px'>{icon}</span>{percent}%",
    "format-icons": ["ůįÉě", "ůįÉü", "ůįÉ†"],
    "on-click": "$HOME/.config/hypr/scripts/cycle_wall.sh" ,
  },

  "custom/weather": {
    "exec": "${HOME}/.config/waybar/scripts/get_weather.sh Ho_Chi_Minh",
    "on-click": "${HOME}/.config/waybar/scripts/get_weather.sh Ho_Chi_Minh",
    "return-type": "json",
    "format": "{}",
    "tooltip": true,
    "interval": 3600
  }
}
